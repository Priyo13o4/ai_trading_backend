# =================================================================
# Environment template (placeholders only — no secrets)
# =================================================================

# Core URLs
API_BASE_URL=CHANGE_ME
FRONTEND_URL=CHANGE_ME
N8N_BASE_URL=CHANGE_ME
N8N_EDITOR_BASE_URL=CHANGE_ME
WEBHOOK_URL=CHANGE_ME

# Cloudflare Tunnel
TUNNEL_ID=CHANGE_ME

# Database
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Trading bot DB name (used by API)
TRADING_BOT_DB=CHANGE_ME

# Redis (app cache/pubsub/ohlc)
REDIS_HOST=redis-app
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME

# =============================================================================
# REDIS TOPOLOGY (Phase 4-D)
# =============================================================================
# Redis role isolation is the default compose topology:
#
# 1. n8n queue workers use redis-queue:
#    QUEUE_BULL_REDIS_HOST=redis-queue
#    QUEUE_BULL_REDIS_PORT=6379
#
# 2. Python services (api-web/api-sse/api-worker) use redis-app:
#    APP_REDIS_URL=redis://:${REDIS_PASSWORD}@redis-app:6379/0
#
# Redis Role Architecture:
# - redis-queue: n8n queue operations (maxmemory-policy: noeviction)
# - redis-app: api-web/sse cache/pubsub/locks (maxmemory-policy: allkeys-lru)
# - redis-sessions: auth sessions (no persistence - ephemeral)
#
# Optional environment variables:
# QUEUE_BULL_REDIS_HOST=redis-queue  # For n8n queue isolation
# QUEUE_BULL_REDIS_PORT=6379
# APP_REDIS_URL=redis://:CHANGE_ME@redis-app:6379/0  # For api-web/sse isolation
# QUEUE_REDIS_URL=redis://:CHANGE_ME@redis-queue:6379/0  # (alternative format)
# =============================================================================

# Redis password (shared secret for session redis if same password)
# SESSION_REDIS_PASSWORD can differ from REDIS_PASSWORD

# Redis sessions (cookie auth)
SESSION_REDIS_HOST=redis-sessions
SESSION_REDIS_PORT=6379
SESSION_REDIS_DB=0
SESSION_REDIS_PASSWORD=CHANGE_ME

# Auth sessions
SERVER_SESSION_MAX_TTL=86400
PERMS_CACHE_TTL_SECONDS=900
SESSION_COOKIE_NAME=session
CSRF_COOKIE_NAME=csrf_token
COOKIE_SECURE=1
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.pipfactor.com
SESSION_BINDING_MODE=off
DEBUG_ENABLED=0
DEBUG_CHANNELS=
DEBUG_SAMPLING_RATE=1.0
AUTH_INVALIDATION_WEBHOOK_SECRET=CHANGE_ME
AUTH_INVALIDATION_USE_SIGNED=1
AUTH_INVALIDATION_TOLERANCE_SECONDS=300

# Rate limiting
RATE_LIMIT_PER_MIN=60

# Anon (unauthenticated) access quota
ANON_HMAC_SECRET=CHANGE_ME
ANON_FREE_LIMIT=3
ANON_COOKIE_NAME=anon_pass

# Cloudflare Turnstile (server-side verification)
# Get the SECRET KEY (not site key) from Cloudflare Dashboard → Turnstile → your widget
TURNSTILE_SECRET_KEY=CHANGE_ME

# CORS (allowlist + regex). Keep localhost + https://*.pipfactor.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,https://pipfactor.com,https://www.pipfactor.com
ALLOWED_ORIGIN_REGEX=^https://([a-zA-Z0-9_-]+\.)*pipfactor\.com$
ALLOWED_CORS_HEADERS=Content-Type,X-CSRF-Token,Authorization,X-Requested-With,X-API-Key

# MT5 ingest (optional)
MT5_INGEST_ENABLE=true
MT5_INGEST_HOST=0.0.0.0
MT5_INGEST_PORT=9001

# Worker scheduler lock/heartbeat
WORKER_LOCK_KEY=locks:data_updater_scheduler
WORKER_LOCK_TTL_SECONDS=420
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_MAX_AGE_SECONDS=180

# SSE stream toggles
# Phase-3 observation mode: keep mux opt-in until rollout is complete.
ENABLE_SIGNAL_MUX_SSE=0

# SSE pubsub connection pool (api-sse/api-web process local).
# Guidance: start at 50, increase if you expect many concurrent SSE streams.
SSE_PUBSUB_POOL_SIZE=50

# SSE mux observability (process local, sampled logs).
SSE_OBS_ENABLED=0
SSE_OBS_TOPIC_SAMPLE_EVERY=100
SSE_OBS_RECONNECT_WINDOW_SECONDS=30

# n8n Auth
N8N_BASIC_AUTH_USER=CHANGE_ME
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME

# api-web error alerts to n8n webhooks
N8N_ERROR_ALERT_BASE_URL=https://n8n.example.com/webhook/<webhook-id>/error-alert
N8N_ERROR_ALERT_ENABLED=0
N8N_ERROR_ALERT_TIMEOUT_SECONDS=5
N8N_ERROR_ALERT_SECRET=CHANGE_ME
N8N_ERROR_ALERT_DEDUP_WINDOW_SECONDS=90
N8N_ERROR_ALERT_RATE_LIMIT_WINDOW_SECONDS=60
N8N_ERROR_ALERT_RATE_LIMIT_MAX_EVENTS=30
N8N_ERROR_ALERT_MAX_RETRIES=2
N8N_ERROR_ALERT_BACKOFF_BASE_SECONDS=0.5
N8N_ERROR_ALERT_BACKOFF_MAX_SECONDS=6
N8N_ERROR_ALERT_CIRCUIT_FAIL_THRESHOLD=5
N8N_ERROR_ALERT_CIRCUIT_OPEN_SECONDS=60

# Supabase
SUPABASE_URL=CHANGE_ME
SUPABASE_PROJECT_URL=CHANGE_ME
SUPABASE_JWKS_URL=CHANGE_ME
SUPABASE_AUDIENCE=authenticated
SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SIGNING_KID=CHANGE_ME
SUPABASE_SECRET_KEY=CHANGE_ME

# API Keys
GEMINI_API_KEY=CHANGE_ME
N8N_MARKET_DATA_KEY=CHANGE_ME

# Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_PERSONAL_CHAT_ID=CHANGE_ME
TELEGRAM_GROUP_CHAT_ID=CHANGE_ME
TELEGRAM_CHANNEL_ID=CHANGE_ME

# Email
EMAIL_USER=CHANGE_ME
EMAIL_PASSWORD=CHANGE_ME

# Plisio
PLISIO_API_KEY=CHANGE_ME
PLISIO_CALLBACK_URL=CHANGE_ME
PLISIO_CALLBACK_URL_LOCAL=http://localhost:8080/api/webhooks/plisio
PLISIO_CALLBACK_URL_PROD=https://api.your-domain.com/api/webhooks/plisio
PLISIO_CRYPTO_CURRENCY=USDT

# -----------------------------------------------------------------
# Additional parity keys (must exist in local/prod/example)
# -----------------------------------------------------------------
APP_ENV=production
AUTH_ENV=production
API_WEB_ENV_FILE=./.env
API_SSE_ENV_FILE=./.env
API_WORKER_ENV_FILE=./.env
TRUST_PROXY_HEADERS=1
AUTHDBG_ENABLED=0
AUTH_EXTRA_ALLOWED_DOMAINS=your-domain.com
GUNICORN_WORKERS=4
SSE_WORKERS=1
N8N_SECURE_COOKIE=true

QUEUE_BULL_REDIS_HOST=redis-queue
QUEUE_BULL_REDIS_PORT=6379
QUEUE_REDIS_URL=redis://:CHANGE_ME@redis-queue:6379/0
APP_REDIS_URL=redis://:CHANGE_ME@redis-app:6379/0

SUPABASE_PUBLISHABLE_KEY=CHANGE_ME

# Razorpay
RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
RAZORPAY_PLAN_ID_CORE=CHANGE_ME

# Dead letter monitoring
SLACK_DEAD_LETTER_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Referral program
REFERRAL_REWARD_EVALUATION_ENABLED=true
REFERRAL_REWARD_TRANSITIONS_ENABLED=true
REFERRAL_PAUSE_RESUME_WORKER_ENABLED=true
REFERRAL_REWARD_HOLD_DAYS=7
REFERRAL_REWARD_FREE_MONTHS_PER_CLAIM=1
REFERRAL_PAUSE_RESUME_INTERVAL_SECONDS=3600
REFERRAL_PAUSE_RESUME_LEAD_SECONDS=120
