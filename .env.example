# =================================================================
# Environment template (placeholders only — no secrets)
# =================================================================

# Core URLs
API_BASE_URL=CHANGE_ME
FRONTEND_URL=CHANGE_ME
N8N_BASE_URL=CHANGE_ME
N8N_EDITOR_BASE_URL=CHANGE_ME
WEBHOOK_URL=CHANGE_ME

# Cloudflare Tunnel
TUNNEL_ID=CHANGE_ME

# Database
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Trading bot DB name (used by API)
TRADING_BOT_DB=CHANGE_ME

# Redis (cache/pubsub/ohlc)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME

# Redis password (shared secret for session redis if same password)
# SESSION_REDIS_PASSWORD can differ from REDIS_PASSWORD

# Redis sessions (cookie auth)
SESSION_REDIS_HOST=redis-sessions
SESSION_REDIS_PORT=6379
SESSION_REDIS_DB=0
SESSION_REDIS_PASSWORD=CHANGE_ME

# Auth sessions
SERVER_SESSION_MAX_TTL=86400
PERMS_CACHE_TTL_SECONDS=900
SESSION_COOKIE_NAME=session
CSRF_COOKIE_NAME=csrf_token
COOKIE_SECURE=1
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.pipfactor.com
SESSION_BINDING_MODE=off
AUTHDBG_ENABLED=0
AUTH_INVALIDATION_WEBHOOK_SECRET=CHANGE_ME
AUTH_INVALIDATION_USE_SIGNED=1
AUTH_INVALIDATION_TOLERANCE_SECONDS=300

# Rate limiting
RATE_LIMIT_PER_MIN=60

# Anon (unauthenticated) access quota
ANON_HMAC_SECRET=CHANGE_ME
ANON_FREE_LIMIT=3
ANON_COOKIE_NAME=anon_pass

# Cloudflare Turnstile (server-side verification)
# Get the SECRET KEY (not site key) from Cloudflare Dashboard → Turnstile → your widget
TURNSTILE_SECRET_KEY=CHANGE_ME

# CORS (allowlist + regex). Keep localhost + https://*.pipfactor.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,https://pipfactor.com,https://www.pipfactor.com
ALLOWED_ORIGIN_REGEX=^https://([a-zA-Z0-9_-]+\.)*pipfactor\.com$
ALLOWED_CORS_HEADERS=Content-Type,X-CSRF-Token,Authorization,X-Requested-With,X-API-Key

# MT5 ingest (optional)
MT5_INGEST_ENABLE=true
MT5_INGEST_HOST=0.0.0.0
MT5_INGEST_PORT=9001

# Worker scheduler lock/heartbeat
WORKER_LOCK_KEY=locks:data_updater_scheduler
WORKER_LOCK_TTL_SECONDS=420
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_MAX_AGE_SECONDS=180

# SSE stream toggles
# Phase-3 observation mode: keep mux opt-in until rollout is complete.
ENABLE_SIGNAL_MUX_SSE=0

# SSE pubsub connection pool (api-sse/api-web process local).
# Guidance: start at 50, increase if you expect many concurrent SSE streams.
SSE_PUBSUB_POOL_SIZE=50

# SSE mux observability (process local, sampled logs).
SSE_OBS_ENABLED=0
SSE_OBS_TOPIC_SAMPLE_EVERY=100
SSE_OBS_RECONNECT_WINDOW_SECONDS=30

# n8n Auth
N8N_BASIC_AUTH_USER=CHANGE_ME
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME

# Supabase
SUPABASE_URL=CHANGE_ME
SUPABASE_PROJECT_URL=CHANGE_ME
SUPABASE_JWKS_URL=CHANGE_ME
SUPABASE_AUDIENCE=authenticated
SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SIGNING_KID=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# API Keys
GEMINI_API_KEY=CHANGE_ME
N8N_MARKET_DATA_KEY=CHANGE_ME
N8N_STRATEGY_PUBLISH_KEY=CHANGE_ME
TWELVE_DATA_API_KEY=CHANGE_ME
TWELVE_DATA_API_KEY_2=CHANGE_ME
MASSIVE_API_KEY=CHANGE_ME

# Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_PERSONAL_CHAT_ID=CHANGE_ME
TELEGRAM_GROUP_CHAT_ID=CHANGE_ME
TELEGRAM_CHANNEL_ID=CHANGE_ME

# Email
EMAIL_USER=CHANGE_ME
EMAIL_PASSWORD=CHANGE_ME

# Plisio
PLISIO_API_KEY=CHANGE_ME
PLISIO_CALLBACK_URL=CHANGE_ME
PLISIO_CRYPTO_CURRENCY=USDT
